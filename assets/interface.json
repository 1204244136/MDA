    "controller": [
        // {
        //     "name": "安卓端",
        //     "type": "Adb",
        //     "display_short_side": 720 // 默认缩放分辨率的短边长度
        // },
        {
            "name": "Win32-Front",
            "type": "Win32",
            "win32": {
                "class_regex": "UnityWndClass",
                "window_regex": "NIKKE",
                "screencap": "ScreenDC",
                "mouse": "Seize",
                "keyboard": "Seize"
            },
            "permission_required": true
        },
        {
            "name": "Win32-Window-Background",
            "type": "Win32",
            "win32": {
                "class_regex": "UnityWndClass",
                "window_regex": "NIKKE",
                "screencap": "Background",
                "mouse": "SendMessageWithCursorPos",
                "keyboard": "PostMessage"
            },
            "permission_required": true
        }
    ],
    "resource": [
        {
            "name": "国际服",
            "path": [
                "./resource"
            ]
        }
    ],
