{
    "task": [
        {
            "name": "Shop",
            "label": "$task.Shop.label",
            "entry": "Shop",
            "description": "$task.Shop.description",
            "option": [
                "CommonShopFreeGoods",
                "CommonShopCoreDustCase",
                "ArenaShopItemList",
                "RecyclingShopList"
            ],
            "group": [
                "daily"
            ]
        }
    ],
    "option": {
        "CommonShopFreeGoods": {
            "type": "switch",
            "label": "$option.CommonShopFreeGoods.label",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "FreeGoodsPurchase": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "FreeGoodsPurchase": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "CommonShopCoreDustCase": {
            "type": "switch",
            "label": "$option.CommonShopCoreDustCase.label",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "CoreDustCasePurchase": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "CoreDustCasePurchase": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "ArenaShopItemList": {
            "type": "checkbox",
            "label": "$option.ArenaShopItemList.label",
            "cases": [
                {
                    "name": "ArenaShopFireCodeManual",
                    "label": "$option.ArenaShopItemList.ArenaShopFireCodeManual",
                    "pipeline_override": {
                        "FireCodeManualPurchase": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "ArenaShopWaterCodeManual",
                    "label": "$option.ArenaShopItemList.ArenaShopWaterCodeManual",
                    "pipeline_override": {
                        "WaterCodeManualPurchase": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "ArenaShopWindCodeManual",
                    "label": "$option.ArenaShopItemList.ArenaShopWindCodeManual",
                    "pipeline_override": {
                        "WindCodeManualPurchase": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "ArenaShopElecCodeManual",
                    "label": "$option.ArenaShopItemList.ArenaShopElecCodeManual",
                    "pipeline_override": {
                        "ElecCodeManualPurchase": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "ArenaShopIronCodeManual",
                    "label": "$option.ArenaShopItemList.ArenaShopIronCodeManual",
                    "pipeline_override": {
                        "IronCodeManualPurchase": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "ArenaShopCodeManualSelectionBox",
                    "label": "$option.ArenaShopItemList.ArenaShopCodeManualSelectionBox",
                    "pipeline_override": {
                        "CodeManualSelectionBoxPurchase": {
                            "enabled": true
                        }
                    }
                }
            ]
        },
        "RecyclingShopList": {
            "type": "checkbox",
            "label": "$option.RecyclingShopList.label",
            "cases": [
                {
                    "name": "GoodTeamworkBox",
                    "label": "$option.RecyclingShopList.GoodTeamworkBox",
                    "pipeline_override": {
                        "GoodTeamworkBoxPurchase": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "MaintenanceKitBox",
                    "label": "$option.RecyclingShopList.MaintenanceKitBox",
                    "pipeline_override": {
                        "MaintenanceKitBoxPurchase": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "CuratedManufacturerArms",
                    "label": "$option.RecyclingShopList.CuratedManufacturerArms",
                    "pipeline_override": {
                        "CuratedManufacturerArmsPurchase": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "Gem",
                    "label": "$option.RecyclingShopList.Gem",
                    "pipeline_override": {
                        "GemPurchase": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "Voucher",
                    "label": "$option.RecyclingShopList.Voucher",
                    "pipeline_override": {
                        "VoucherPurchase": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "UpgradeMaterials",
                    "label": "$option.RecyclingShopList.UpgradeMaterials",
                    "pipeline_override": {
                        "UpgradeMaterialsPurchase": {
                            "enabled": true
                        }
                    }
                }
            ]
        }
    }
}
